[60.117365, "o", "\r\n"]
[60.117631, "o", "\u001b[1;33m[bandit → status]\u001b[0m Checking connection health...\r\n"]
[67.127, "o", "  \u001b[0;32m✓\u001b[0m connected to 127.0.0.1:6667 as bandit (uptime: 3s, channels: #general, #gate)\r\n\r\n\u001b[0;36m=== Demo complete ===\u001b[0m\r\n\r\nIn production with Claude Code:\r\n  HIGH priority (mentions, DMs, #gate) → Claude acts on them immediately\r\n"]
[67.127514, "o", "  NORMAL (other channels) → throttled summaries, Claude reads when convenient\r\n  fetch_history → Claude catches up on missed messages\r\n\r\n"]
