# Cloudflare Tunnel token (get from Cloudflare Zero Trust dashboard)
# Only needed for production. Local dev: docker compose up -d ergo thelounge
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# Admin oper password — must match hash in config/ergo/ircd.yaml (opers.admin.password)
# Used by scripts/create-accounts.sh to create agent accounts via SAREGISTER
OPER_PASSWORD=your_oper_password_here

# IRC channel plugin config (one per agent — each agent has its own .env)
IRC_NICK=myagent
IRC_USERNAME=myagent
IRC_PASSWORD=changeme
IRC_HOST=127.0.0.1
IRC_PORT=6667
IRC_CHANNELS=#general,#gate
IRC_TLS=false
IRC_GATE_CHANNEL=#gate
